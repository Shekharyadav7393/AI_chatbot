# Application
APP_NAME="AI Customer Support Chatbot"
DEBUG=True
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatbot_db

# JWT Auth
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Provider
# auto = Gemini if GEMINI_API_KEY is present, otherwise local Hugging Face.
AI_PROVIDER=auto

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=60

# Local offline LLM
# Use a local model directory or a Hugging Face model that is already cached on this machine.
LOCAL_LLM_MODEL=google/flan-t5-base
LOCAL_LLM_TASK=text2text-generation
LOCAL_LLM_MAX_NEW_TOKENS=256
LOCAL_LLM_TEMPERATURE=0.1
TRANSFORMERS_OFFLINE=True

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=vectorstore/chroma
CHROMA_COLLECTION_NAME=company_knowledge_base

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Rate Limiting
RATE_LIMIT=100/minute

# RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
VECTOR_DIMENSION=384
RETRIEVAL_SCORE_THRESHOLD=0.35

# Logging
LOG_LEVEL=INFO
